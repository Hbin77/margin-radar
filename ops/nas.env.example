# ops/sync_from_nas.sh 설정 (실제 값은 ops/nas.env 에, git 커밋 금지)
NAS_HOST=your.nas.host
NAS_PORT=22
NAS_USER=youruser
NAS_DIR=/volume1/your/path/margin-radar
NAS_KEY=/home/hbin/.ssh/mr_nas_deploy
APP_DIR=/home/hbin/apps/margin-radar
# 웹 컨테이너가 마운트하는 라이브 data.json 경로(git 외부, 배포 reset 무영향)
DATA_FILE=/home/hbin/mr-shared/data.json
